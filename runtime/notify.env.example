# Optional Telegram alerting for metrics-watch.sh — copy to notify.env and fill in.
#   cp notify.env.example notify.env && chmod 600 notify.env
# notify.env is gitignored and stays on the head node only. If it is absent (or the
# values are blank) the watcher is a strict no-op — WARNs still go to journald + the
# rotating log, just not to Telegram.
#
# How to get these:
#   1. Create a bot: message @BotFather on Telegram, /newbot, copy the token.
#   2. Get your chat id: DM your new bot once, then open
#      https://api.telegram.org/bot<TOKEN>/getUpdates and read result[].message.chat.id
#      (a personal chat is a positive integer; a group/supergroup is negative).

TG_BOT_TOKEN=
TG_CHAT_ID=

# Optional: only for forum-topic supergroups — the numeric topic (thread) id to post
# into. Leave blank to post to the chat's General topic.
TG_THREAD_ID=
