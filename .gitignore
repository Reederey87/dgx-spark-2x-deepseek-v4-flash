# Your site-specific config — copy runtime/cluster.env.example to runtime/cluster.env.
# (Pattern has no leading slash, so it matches runtime/cluster.env too.)
cluster.env

# Rendered per-node compose env (generated by render-env.sh; contains host IPs).
.env.dspark

# Optional Telegram alert credentials for metrics-watch — copy from notify.env.example.
notify.env

# Runtime state written on the head node by metrics-watch / warmup.
.metrics-watch*
logs/

# SSH keys / public keys — never commit.
*.key
*.pub
id_ed25519*
nvsync*

# Benchmark + run logs.
*.log
nccl-bench-*
/tmp/

# OS / editor cruft.
.DS_Store
*.swp
*~
